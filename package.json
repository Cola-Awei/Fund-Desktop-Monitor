{
  "name": "fund-desktop-monitor",
  "version": "0.1.0",
  "description": "Compact desktop fund real-time profit/loss monitor",
  "main": "dist-electron/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build:icon": "node scripts/render-tray-icon.mjs",
    "build": "npm run build:icon && npm run test && npm run build:renderer && npm run build:electron && npm run build:preload",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "build:preload": "node scripts/build-preload.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run build && electron-builder --win dir",
    "package:installer": "npm run build && electron-builder --win nsis"
  },
  "build": {
    "appId": "local.fund.desktop.monitor",
    "productName": "Fund Desktop Monitor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "build/icon.png",
      "package.json"
    ],
    "win": {
      "target": "dir",
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron-store": "^10.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitest/ui": "^2.1.8",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "jsdom": "^25.0.1",
    "sharp": "^0.33.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  }
}
